{{- $distrobox := false -}}

{{- if (eq .chezmoi.hostname "lnx-stwsh") -}}
{{- $distrobox = true -}}
{{- end -}}

[edit]
  apply = true

[diff]
  command = "difft"
  args = ["--color", "always", "--skip-unchanged"]
  pager = "bat"
  exclude = ['scripts']

[git]
  autoCommit = true
  autoPush = false

[bitwarden]
  unlock = "auto"

[data]
distrobox = {{ $distrobox }}
