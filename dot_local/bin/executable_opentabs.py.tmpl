#!/usr/bin/env python3

import sys
import requests

if len(sys.argv) < 2:
    print("Usage: bookmarks.py <query>")
    sys.exit(1)

query = sys.argv[1]

response = requests.get(
    "https://linkding.adminforge.de/api/bookmarks/?q=%23cw16%2F2026",
    params={"q": query},
    headers={'Authorization': 'Token {{ (bitwardenFields "item" "linkding").token.value }}'})
)
response.raise_for_status()
data = response.json()

lines = []
tags = set()

for b in data["results"]:
    title = b["title"]
    url = b["url"]
    link = f"[{title}]({url})"
    notes = (b["notes"] or "").replace("@@link@@", link).strip()
    tags.update(b["tag_names"])

    if "@@link@@" in (b["notes"]):
        lines.append(f"* {notes}")
    else:
        lines.append(f"* {link}: {notes}")

sorted_tags = sorted(tags)
tags_formatted = ", ".join(f'"{t}"' for t in sorted_tags)

print(f"Tags: [{tags_formatted}]\n\n")

print("\n".join(lines))
