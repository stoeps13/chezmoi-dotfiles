export DISABLE_AUTO_TITLE='true'

if [ -n "$CONTAINER_ID" ]; then
  if [ $CONTAINER_ID = kali ]; then
    psvar[1]="@%F{green}${(%):-$CONTAINER_ID 👽}"     # show hostname inside docker containers
    # 🤯
  else
    psvar[1]="@%F{yellow}${(%):-$CONTAINER_ID 📦}"     # show hostname inside docker containers
    #psvar[1]="@%F{yellow}${(%):-$CONTAINER_ID 🧰}"     # show hostname inside docker containers
  fi
else
    psvar[1]="@%F{blue}${(%):-$(hostname)}"     # show hostname inside podman containers
fi

# Context: user@hostname (who am I and where am I)
prompt_context() {
  if [[ "$USER" != "$DEFAULT_USER" || -n "$SSH_CLIENT" ]]; then
    prompt_segment black default "%(!.%{%F{yellow}%}.)$USER$psvar"
  fi
}
export SSH_AUTH_SOCK=/run/user/1000/keyring/ssh

