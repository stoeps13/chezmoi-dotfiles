[calendars]

#  [[home]]
#    path = ~/.calendars/home/
#    color = dark green
#    priority = 20
#
  [[work]]
    path = ~/.local/share/calendars/calendar/
    color = dark blue
  [[zep]]
    path = ~/.local/share/calendars/ZEP/
  [[dnug events]]
    path = ~/.local/share/calendar-dnug/
    color = dark red

  [[birthdays]]
    path = ~/.local/share/calendar-nc/contact_birthdays
    color = dark magenta
  [[feiertage]]
    path = ~/.local/share/calendar-nc/Feiertage+in+Deutschland+%28Google+Calendar+import%29
  [[personal]]
    path = ~/.local/share/calendar-nc/personal
    color = dark green
  [[werlestrasse]]
    path = ~/.local/share/calendar-nc/Werlestra%C3%9Fe+%28Google+Calendar+import%29
    color = brown

[locale]
local_timezone= Europe/Berlin
default_timezone= Europe/Berlin
timeformat= %H:%M
dateformat= %d.%m.
longdateformat= %d.%m.%Y
datetimeformat= %d.%m. %H:%M
longdatetimeformat= %d.%m.%Y %H:%M

[view]
event_format={calendar-color}{cancelled}{start}-{end} {title}{repeat-symbol}{reset}
agenda_event_format={calendar-color}{cancelled}{start-end-time-style} {title}{repeat-symbol}{reset}
