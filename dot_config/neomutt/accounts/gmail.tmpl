set realname="Christoph Stoettner"
set from="{{ (bitwarden "item" "Googlemail SMTP").login.username }}"
set use_from=yes

set sendmail='msmtp -a gmail'

set mbox_type = Maildir
set folder = "~/.local/share/mail/gmail/"

set spoolfile=+Inbox
set record="+[Gmail]/Sent Mail"
set postponed="+[Gmail]/Drafts"

set signature = "$XDG_CONFIG_HOME/neomutt/sigs/gmail.signature"

set mail_check_stats
# You can use any gmail imap mailboxes

mailboxes =Inbox =[Gmail]/Sent\ Mail =[Gmail]/Drafts =[Gmail]/Archive =Archive/2023 =Archive/2024

# Yearly archives
save-hook ~r01/01/2023-31/12/2023 =Archive/2023
save-hook ~r01/01/2024-31/12/2024 =Archive/2024

